#!/usr/bin/env bash
# gh shim — logs all calls and returns canned responses for audit_env.py.
LOG="${CONCIERGE_EVAL_CALL_LOG:-/dev/null}"
echo "gh $*" >> "$LOG"

case "$1" in
  --version)
    echo "${CONCIERGE_EVAL_GH_VERSION:-gh version 2.91.0 (2026-04-16)}"
    echo "https://github.com/cli/cli/releases/tag/v2.91.0"
    ;;
  release)
    # Expect: gh release view --repo <owner>/<repo> --json tagName
    shift
    [ "$1" = "view" ] && shift
    repo=""
    while [ $# -gt 0 ]; do
      case "$1" in
        --repo) repo="$2"; shift 2 ;;
        *) shift ;;
      esac
    done
    case "$repo" in
      gastownhall/gastown)   echo '{"tagName":"v1.0.0"}' ;;
      safishamsi/graphify)   echo '{"tagName":"v0.4.29"}' ;;
      rtk-ai/rtk)            echo '{"tagName":"v0.37.2"}' ;;
      cli/cli)               echo '{"tagName":"v2.91.0"}' ;;
      *)                     echo '{"tagName":"v0.0.0"}' ;;
    esac
    ;;
  *)
    echo "gh-shim: unhandled args: $*" >&2
    exit 1
    ;;
esac
